{
  "name": "simple-sops",
  "displayName": "Simple SOPS",
  "description": "Seamlessly decrypt, edit, and re-encrypt SOPS files",
  "version": "0.0.1",
  "publisher": "muniter",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onFileSystem:sops",
    "onLanguage:yaml",
    "onLanguage:json",
    "onLanguage:plaintext",
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sops.decrypt",
        "title": "SOPS: Decrypt and Open",
        "icon": "$(lock)"
      },
      {
        "command": "sops.showOutput",
        "title": "SOPS: Show Output Log"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "sops.decrypt",
          "when": "resourceFilename =~ /\\.(sops|enc)\\./",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "sops.decrypt",
          "when": "resourceFilename =~ /\\.(sops|enc)\\./"
        }
      ],
      "editor/title": [
        {
          "command": "sops.decrypt",
          "when": "resourceFilename =~ /\\.(sops|enc)\\./ && config.sops.showDecryptButton",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Simple SOPS",
      "properties": {
        "sops.action": {
          "type": "string",
          "default": "auto-open",
          "enum": [
            "auto-open",
            "prompt",
            "do-nothing"
          ],
          "enumDescriptions": [
            "Automatically decrypt and open SOPS files when detected",
            "Show a notification asking whether to decrypt",
            "Do nothing — use the 'SOPS: Decrypt and Open' command manually"
          ],
          "description": "What to do when a SOPS encrypted file is opened."
        },
        "sops.encryptedFileTab": {
          "type": "string",
          "default": "close",
          "enum": [
            "close",
            "keep"
          ],
          "enumDescriptions": [
            "Close the encrypted file tab after opening the decrypted view",
            "Keep the encrypted file tab open alongside the decrypted view"
          ],
          "description": "What to do with the encrypted file tab after decrypting."
        },
        "sops.showDecryptButton": {
          "type": "boolean",
          "default": true,
          "description": "Show a decrypt icon button in the editor title bar for SOPS files."
        },
        "sops.env": {
          "type": "object",
          "default": {},
          "description": "Environment variables to pass to sops. Path-like variables (e.g. SOPS_AGE_KEY_FILE) are resolved relative to the workspace root.",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test --label unit",
    "test:integration": "vscode-test --label integration",
    "test:all": "vscode-test"
  },
  "dependencies": {
    "xstate": "^5.30.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/sinon": "^17.0.4",
    "sinon": "^19.0.2",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
