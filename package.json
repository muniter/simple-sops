{
  "name": "simple-sops",
  "displayName": "Simple SOPS",
  "description": "Seamlessly decrypt, edit, and re-encrypt SOPS files",
  "version": "0.0.3",
  "publisher": "javierlopez",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/muniter/simple-sops"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.114.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "sops",
    "secrets",
    "encryption",
    "decrypt",
    "age",
    "kms"
  ],
  "activationEvents": [
    "onFileSystem:sops",
    "onLanguage:yaml",
    "onLanguage:json",
    "onLanguage:plaintext",
    "onStartupFinished"
  ],
  "main": "./src/extension.ts",
  "contributes": {
    "commands": [
      {
        "command": "sops.decrypt",
        "title": "SOPS: Decrypt and Open",
        "icon": "$(lock)"
      },
      {
        "command": "sops.showOutput",
        "title": "SOPS: Show Output Log"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "sops.decrypt",
          "when": "resourceFilename =~ /\\.(sops|enc)\\./",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "sops.decrypt",
          "when": "resourceFilename =~ /\\.(sops|enc)\\./"
        }
      ],
      "editor/title": [
        {
          "command": "sops.decrypt",
          "when": "resourceFilename =~ /\\.(sops|enc)\\./ && config.sops.showDecryptButton",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Simple SOPS",
      "properties": {
        "sops.action": {
          "type": "string",
          "default": "auto-open",
          "enum": [
            "auto-open",
            "prompt",
            "do-nothing"
          ],
          "enumDescriptions": [
            "Automatically decrypt and open SOPS files when detected",
            "Show a notification asking whether to decrypt",
            "Do nothing - use the 'SOPS: Decrypt and Open' command manually"
          ],
          "description": "What to do when a SOPS encrypted file is opened."
        },
        "sops.encryptedFileTab": {
          "type": "string",
          "default": "keep",
          "enum": [
            "keep",
            "close"
          ],
          "enumDescriptions": [
            "Close the encrypted file tab after opening the decrypted view",
            "Keep the encrypted file tab open alongside the decrypted view"
          ],
          "description": "What to do with the encrypted file tab after decrypting."
        },
        "sops.showDecryptButton": {
          "type": "boolean",
          "default": true,
          "description": "Show a decrypt icon button in the editor title bar for SOPS files."
        },
        "sops.env": {
          "type": "object",
          "default": {},
          "description": "Environment variables to pass to sops. Path-like variables (e.g. SOPS_AGE_KEY_FILE) are resolved relative to the workspace root.",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run lint && pnpm run test && pnpm run compile:integration",
    "compile:integration": "tsc -p tsconfig.integration.json",
    "watch": "tsgo -watch -p ./ --noEmit",
    "typecheck": "tsgo -p ./ --noEmit && tsc -p tsconfig.integration.json --noEmit",
    "eslint": "eslint src",
    "knip": "knip",
    "knip:production": "knip --production",
    "lint": "pnpm run eslint && pnpm run typecheck && pnpm run knip",
    "test": "node --test tests/unit/**/*.test.ts",
    "test:integration": "pnpm run compile:integration && vscode-test --label integration",
    "test:all": "pnpm run test && pnpm run test:integration"
  },
  "dependencies": {
    "xstate": "^5.30.0"
  },
  "knip": {
    "entry": [
      "tests/unit/**/*.test.ts",
      "tests/integration/**/*.test.ts",
      ".vscode-test.mjs"
    ],
    "ignoreDependencies": [
      "@vscode/test-electron"
    ]
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/sinon": "^17.0.4",
    "@types/vscode": "^1.114.0",
    "@typescript/native-preview": "7.0.0-dev.20260404.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "knip": "^6.3.0",
    "sinon": "^19.0.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
