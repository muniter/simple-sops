{
	"compilerOptions": {
		"noEmit": true,
		"module": "NodeNext",
		"target": "ESNext",
		"erasableSyntaxOnly": true,
		"verbatimModuleSyntax": true,
		"allowImportingTsExtensions": true,
		"rootDir": ".",
		"lib": [
			"ESNext"
		],
		"types": [
			"node",
			"vscode"
		],
		"strict": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": ["src", "tests/unit"],
	"exclude": ["node_modules"]
}
