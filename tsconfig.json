{
	"compilerOptions": {
		"module": "NodeNext",
		"target": "ESNext",
		"outDir": "out",
		"lib": [
			"ESNext"
		],
		"types": [
			"node",
			"mocha",
			"vscode"
		],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true
	},
	"include": ["src"],
	"exclude": ["node_modules"]
}
